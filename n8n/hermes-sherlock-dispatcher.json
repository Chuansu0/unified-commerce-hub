        {
            "parameters": {
                "jsCode": "// target=all: 複製給兩個 bot\nconst action = $json;\nconst conanEmoji = '🔍';\nconst ariaEmoji = '🏠';\nconst payloadStr = JSON.stringify(action.payload, null, 2);\n\nreturn [\n\t{ json: { ...action, _dest: 'conan', telegram_text: `${conanEmoji} <b>Sherlock 廣播</b>\\n動作: <code>${action.action_type}</code>\\n\\n<pre>${payloadStr}</pre>` } },\n\t{ json: { ...action, _dest: 'aria', telegram_text: `${ariaEmoji} <b>Sherlock 廣播</b>\\n動作: <code>${action.action_type}</code>\\n\\n<pre>${payloadStr}</pre>` } }\n];"
