{
    "name": "WebChat Inbound Handler",
    "nodes": [
        {
            "id": "webhook-node",
            "name": "WebChat Webhook",
            "type": "n8n-nodes-base.webhook",
            "typeVersion": 1,
            "position": [
                250,
                300
            ],
            "parameters": {
                "httpMethod": "POST",
                "responseMode": "responseNode",
                "path": "chat-inbound",
                "options": {}
            },
            "webhookId": "chat-inbound"
        },
        {
            "id": "set-format",
            "name": "Format Message Data",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                450,
                300
            ],
            "parameters": {
                "mode": "manual",
                "fields": {
                    "values": [
                        {
                            "name": "sessionId",
                            "type": "string",
                            "value": "={{ $json.body.sessionId }}"
                        },
                        {
                            "name": "message",
                            "type": "string",
                            "value": "={{ $json.body.message }}"
                        },
                        {
                            "name": "platform",
                            "type": "string",
                            "value": "={{ $json.body.platform || 'web' }}"
                        },
                        {
                            "name": "timestamp",
                            "type": "string",
                            "value": "={{ $now }}"
                        }
                    ]
                }
            }
        },
        {
            "id": "find-conversation",
            "name": "Find Conversation",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                650,
                200
            ],
            "parameters": {
                "method": "GET",
                "url": "http://pocketbase.zeabur.internal:8090/api/collections/conversations/records",
                "sendQuery": true,
                "queryParameters": {
                    "parameters": [
                        {
                            "name": "filter",
                            "value": "=(telegram_chat_id='{{ $json.sessionId }}')"
                        }
                    ]
                },
                "options": {}
            }
        },
        {
            "id": "check-conversation-exists",
            "name": "Conversation Exists?",
            "type": "n8n-nodes-base.if",
            "typeVersion": 2,
            "position": [
                850,
                200
            ],
            "parameters": {
                "conditions": {
                    "options": {
                        "caseSensitive": true,
                        "leftValue": "",
                        "typeValidation": "strict"
                    },
                    "conditions": [
                        {
                            "id": "c7d800ee-07a9-4f44-96e7-297c0b925d96",
                            "leftValue": "={{ $json.totalItems }}",
                            "rightValue": 0,
                            "operator": {
                                "type": "number",
                                "operation": "gt"
                            }
                        }
                    ]
                }
            }
        },
        {
            "id": "create-conversation",
            "name": "Create Conversation",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1050,
                100
            ],
            "parameters": {
                "method": "POST",
                "url": "http://pocketbase.zeabur.internal:8090/api/collections/conversations/records",
                "sendBody": true,
                "contentType": "json",
                "body": {
                    "telegram_chat_id": "={{ $node['Format Message Data'].json.sessionId }}",
                    "platform": "web",
                    "status": "active",
                    "last_message": "={{ $node['Format Message Data'].json.message }}",
                    "last_message_at": "={{ $node['Format Message Data'].json.timestamp }}"
                },
                "options": {}
            }
        },
        {
            "id": "extract-existing-conversation",
            "name": "Extract Conversation ID",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                1050,
                300
            ],
            "parameters": {
                "mode": "manual",
                "fields": {
                    "values": [
                        {
                            "name": "conversationId",
                            "type": "string",
                            "value": "={{ $json.items[0].id }}"
                        }
                    ]
                }
            }
        },
        {
            "id": "extract-new-conversation",
            "name": "Extract New Conversation ID",
            "type": "n8n-nodes-base.set",
            "typeVersion": 3.4,
            "position": [
                1250,
                100
            ],
            "parameters": {
                "mode": "manual",
                "fields": {
                    "values": [
                        {
                            "name": "conversationId",
                            "type": "string",
                            "value": "={{ $json.id }}"
                        }
                    ]
                }
            }
        },
        {
            "id": "store-message",
            "name": "Store Message",
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                1450,
                200
            ],
            "parameters": {
                "method": "POST",
                "url": "http://pocketbase.zeabur.internal:8090/api/collections/messages/records",
                "sendBody": true,
                "contentType": "json",
                "body": {
                    "conversation": "={{ $json.conversationId }}",
                    "sender": "user",
                    "channel": "={{ $node['Format Message Data'].json.platform }}",
                    "content": "={{ $node['Format Message Data'].json.message }}"
                },
                "options": {}
            }
        },
        {
            "id": "telegram-send",
            "name": "Send to Telegram Group",
            "type": "n8n-nodes-base.telegram",
            "typeVersion": 1.2,
            "position": [
                1450,
                400
            ],
            "parameters": {
                "chatId": "-1003806455231",
                "text": "🌐 WebChat: {{ $node['Format Message Data'].json.message }}\n💬 回覆此訊息以回覆客戶\n@neovegaandrea_bot 新訊息",
                "additionalFields": {
                    "parse_mode": "HTML"
                }
            },
            "credentials": {
                "telegramApi": {
                    "name": "telegram-bot-credential",
                    "id": ""
                }
            }
        },
        {
            "id": "respond",
            "name": "Respond to Webhook",
            "type": "n8n-nodes-base.respondToWebhook",
            "typeVersion": 1.1,
            "position": [
                1650,
                300
            ],
            "parameters": {
                "respondWith": "json",
                "responseBody": "={{ { success: true, message: 'Message forwarded to Telegram' } }}",
                "options": {}
            }
        }
    ],
    "connections": {
        "WebChat Webhook": {
            "main": [
                [
                    {
                        "node": "Format Message Data",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Format Message Data": {
            "main": [
                [
                    {
                        "node": "Find Conversation",
                        "type": "main",
                        "index": 0
                    },
                    {
                        "node": "Send to Telegram Group",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Find Conversation": {
            "main": [
                [
                    {
                        "node": "Conversation Exists?",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Conversation Exists?": {
            "main": [
                [
                    {
                        "node": "Extract Conversation ID",
                        "type": "main",
                        "index": 0
                    }
                ],
                [
                    {
                        "node": "Create Conversation",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Extract Conversation ID": {
            "main": [
                [
                    {
                        "node": "Store Message",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Create Conversation": {
            "main": [
                [
                    {
                        "node": "Extract New Conversation ID",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Extract New Conversation ID": {
            "main": [
                [
                    {
                        "node": "Store Message",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        },
        "Store Message": {
            "main": [
                [
                    {
                        "node": "Respond to Webhook",
                        "type": "main",
                        "index": 0
                    }
                ]
            ]
        }
    },
    "settings": {
        "executionOrder": "v1"
    },
    "staticData": null,
    "tags": []
}