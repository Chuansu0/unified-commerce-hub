# n8n Integration
VITE_USE_N8N=false

# Telegram Bot Token (for n8n credential setup)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# =====================================
# Direct Telegram Bot API (繞過 OpenClaw)
# =====================================
# 使用個人 Bot Token 直接發送訊息到 Telegram，無需 OpenClaw
VITE_TELEGRAM_BOT_TOKEN=your_personal_bot_token_here
VITE_TELEGRAM_USER_ID=your_telegram_user_id
# 或發送到群組
VITE_TELEGRAM_GROUP_ID=your_group_chat_id

# Umio HTTP Bridge (Digital Content Clerk - Direct OpenClaw Connection)
# This bypasses n8n and connects directly to OpenClaw WebSocket Gateway
VITE_UMIO_HTTP_BRIDGE_URL=https://openclaw-http-bridge.zeabur.app/api/umio/chat

# =====================================
# Telegram Webhook (telegram-webhook 服務)
# =====================================
# PocketBase 連線 URL
POCKETBASE_URL=http://pocketbase-convo.zeabur.internal:8090
# OpenClaw Telegram Chat ID (用於轉發訊息)
OPENCLAW_CHAT_ID=-1001234567890
# n8n Webhook URL (用於 Umio 回覆轉發)
N8N_WEBHOOK_URL=https://www.neovega.cc/api/webhook
