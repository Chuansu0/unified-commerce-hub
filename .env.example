# n8n Integration
VITE_USE_N8N=false

# Telegram Bot Token (for n8n credential setup)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Umio HTTP Bridge (Digital Content Clerk - Direct OpenClaw Connection)
# This bypasses n8n and connects directly to OpenClaw WebSocket Gateway
VITE_UMIO_HTTP_BRIDGE_URL=https://openclaw-http-bridge.zeabur.app/api/umio/chat
