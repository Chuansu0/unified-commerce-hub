# Umio HTTP 整合環境變數範例
# 複製此檔案為 .env 或 .env.local 來使用

# OpenClaw HTTP Bridge URL
# 預設：https://openclaw-http-bridge.zeabur.app
VITE_OPENCLAW_BRIDGE_URL=https://openclaw-http-bridge.zeabur.app

# PocketBase URL
# 預設：/pb (相對路徑)
VITE_POCKETBASE_URL=/pb

# 可選：Umio 特定配置
# VITE_UMIO_HTTP_BRIDGE_URL=https://openclaw-http-bridge.zeabur.app
