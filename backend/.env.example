# ── 超級管理員帳號（必填）────────────────────────────
ROOT_ID=admin
ROOT_PASSWORD=YourStr0ngP@ssw0rd!

# ── JWT 密鑰（必填，請使用隨機長字串）─────────────────
# 產生方式：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-string

# ── PostgreSQL 資料庫連線（需在 Zeabur 建立 PostgreSQL 服務）─
# Zeabur 會自動注入此變數，格式：postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/neovega

# ── 允許的前端網域（正式環境請填入實際網域）────────────
CORS_ORIGIN=*

# ── 服務埠號（Zeabur 會自動設定）────────────────────────
PORT=3000

# ── Telegram Bot 配置 ──────────────────────────────────
# Bot: @neovegainsforge_bot
TELEGRAM_BOT_TOKEN=8092224802:AAHlz9w0Qw7rYWfhK6aDQE1pRzHY6XiIrgY
# Webhook URL（部署後的網域）
TELEGRAM_WEBHOOK_URL=https://your-domain.zeabur.app/api/telegram/webhook

# ── OpenClaw Agent URL ─────────────────────────────────
OPENCLAW_AGENT_URL=http://localhost:3000/api/agent
